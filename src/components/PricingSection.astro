---
import Icon from "./Icon.astro";
import { landing } from "../../content/landing";
import { emphasize } from "../utils/richText";

const { pricing } = landing;
const isExternal = (href: string) => href.startsWith("http");

const roiHighlights = [
  ["Et si cet abonnement vous rapportait plus qu'il ne vous coûte ?"],
  ["100 euros par mois pour les non-médecins, 200 euros pour les médecins."],
  ["charge professionnelle, déductible de votre bénéfice imposable"],
  ["vous n'en payez en réalité qu'une fraction."],
  [],
  ["80 à 150 euros chez un naturopathe, 150 à 300 euros chez un médecin fonctionnel."],
  [],
  ["c'est 300 à 2 000 euros par patient."],
  ["un seul nouveau patient venu de Heiven suffit à couvrir votre adhésion."],
  ["négatif."]
];

const committeeHighlights = [
  [],
  ["veiller à ce que chaque membre admis partage les mêmes valeurs et les mêmes exigences de formation, de pratique et d'éthique."],
  ["savent qu'ils peuvent vous faire confiance."]
];

const accessHighlights = [
  ["précisément ce qui le rend précieux."],
  ["pour que chaque membre garde une vraie visibilité, et que l'audience ne soit jamais saturée."],
  [],
  ["Une formation reconnue"],
  ["Au moins six mois de pratique"],
  ["Nous cherchons des praticiens passionnés, compétents et expérimentés, qui ont quelque chose à transmettre."],
  ["Comité des Experts"]
];

const trustHighlights = [
  ["Je ne vais pas vous vendre du rêve."],
  ["Ce que je peux vous garantir, c'est tout le reste."],
  [],
  ["Chaque mois, j'organise des ateliers"],
  [],
  ["On perce plus facilement à plusieurs - de nombreuses collaborations le prouvent déjà."],
  ["Votre réussite est ma réussite."],
  ["plus de 300 000 personnes qui cherchent exactement un praticien comme vous."],
  [],
  ["c'est exactement ce que des publications régulières construisent."],
  ["vous ne feriez pas venir de nouveaux patients."],
  ["Et un seul suffirait largement à rembourser votre investissement."],
  [],
  ["Que vous soyez, tout simplement, qui vous êtes déjà"],
  []
];

const urgencyHighlights = [
  ["Réserver votre place aujourd'hui ne veut pas dire publier demain."],
  [],
  [],
  ["c'est le seul moment de l'année où vous avez le temps."],
  ["septembre est LE grand rendez-vous de la santé."],
  ["une longueur d'avance.", "déjà installé sur Heiven, déjà vu, déjà reconnu"],
  ["Le bon moment pour les remplir, c'est tout l'été."]
];
---

<section class="section section-accent" id="offre" aria-labelledby="pricing-title">
  <div class="section-inner editorial-layout pricing-block">
    <div class="section-copy section-lede">
      <p class="eyebrow">Investissement</p>
      <h2 id="pricing-title">{pricing.roiTitle}</h2>
    </div>
    <article class="story-panel story-panel-primary">
      <div class="problem-copy-block">
          {pricing.roiParagraphs.map((paragraph, index) => (
            <p
              class={index === 0 ? "section-intro lead-paragraph" : "section-intro"}
              set:html={emphasize(paragraph, roiHighlights[index] ?? [])}
            ></p>
          ))}
        </div>
      </article>
  </div>

  <div class="section-inner pricing-block">
    <div class="access-panel">
      <div class="section-copy">
        <h3 class="chapter-title">{pricing.accessTitle}</h3>
        <div class="problem-copy-block">
          {pricing.accessParagraphs.map((paragraph, index) => (
            <p class="section-intro" set:html={emphasize(paragraph, accessHighlights[index] ?? [])}></p>
          ))}
        </div>
      </div>
    </div>
  </div>

  <div class="section-inner pricing-block">
      <div class="section-copy">
        <h3 class="chapter-title">{pricing.committeeTitle}</h3>
        <div class="problem-copy-block">
          {pricing.committeeParagraphs.map((paragraph, index) => (
            <p class="section-intro" set:html={emphasize(paragraph, committeeHighlights[index] ?? [])}></p>
          ))}
        </div>
        <ul class="name-list">
          {pricing.committeeMembers.map((member) => (
            <li><strong>{member.name}</strong>{member.role ? ` ${member.role}` : ""}</li>
          ))}
        </ul>
      </div>

      <div class="committee-mosaic">
        {pricing.committeeGallery.map((member) => (
          <div class="mosaic-cell">
            <img
              src={member.image}
              alt={member.alt}
              loading="lazy"
              decoding="async"
              style={[
                member.objectPosition ? `object-position:${member.objectPosition}` : null,
                member.scale ? `transform:scale(${member.scale})` : null,
                member.scale && member.objectPosition ? `transform-origin:${member.objectPosition}` : null
              ].filter(Boolean).join(";") || undefined}
            />
          </div>
        ))}
      </div>
  </div>

  <div class="section-inner pricing-block">
    <div class="section-copy section-lede">
      <p class="eyebrow">Tarifs</p>
      <h3 class="chapter-title">{pricing.offerTitle}</h3>
      <p class="section-intro offer-intro">{pricing.offerIntro}</p>
      <p class="section-intro" set:html={emphasize(pricing.offerLimit, ["50 places par cycle."])}></p>
    </div>
    <div class="plan-grid">
      {pricing.plans.map((plan) => (
        <article class="pricing-plan">
          <h4>{plan.title}</h4>
          <p class="pricing-price" set:html={emphasize(plan.price, ["100 € / mois", "200 € / mois"])}></p>
          {plan.priceNote ? <p class="pricing-price-note">{plan.priceNote}</p> : null}
          <p class="pricing-desc" set:html={emphasize(plan.description, plan.descriptionBold ?? [])}></p>
          <ul class="feature-list">
            {plan.points.map((item) => (
              <li>
                <Icon name="CircleCheck" class="list-icon" size={16} />
                <span set:html={emphasize(item.text, item.bold ?? [])}></span>
              </li>
            ))}
          </ul>
          <a
            class="button button-primary"
            href={plan.cta.href}
            target={isExternal(plan.cta.href) ? "_blank" : undefined}
            rel={isExternal(plan.cta.href) ? "noreferrer" : undefined}
          >
            {plan.cta.label}
            <Icon name="ArrowRight" class="button-icon" size={16} />
          </a>
        </article>
      ))}
    </div>
    <p class="section-intro pricing-note">{pricing.pricingNote}</p>
  </div>

  <div class="section-inner pricing-block">
    <article class="story-panel">
      <h3 class="chapter-title">{pricing.trustTitle}</h3>
      <div class="problem-copy-block">
        {pricing.trustParagraphs.map((paragraph, index) => (
          <p class="section-intro" set:html={emphasize(paragraph, trustHighlights[index] ?? [])}></p>
        ))}
      </div>
    </article>
  </div>

  <div class="section-inner pricing-block">
    <article class="story-panel story-panel-primary">
      <h3 class="chapter-title">{pricing.urgencyTitle}</h3>
      <div class="problem-copy-block">
        {pricing.urgencyParagraphs.map((paragraph, index) => (
          <p class="section-intro" set:html={emphasize(paragraph, urgencyHighlights[index] ?? [])}></p>
        ))}
      </div>
    </article>
  </div>

  <div class="section-inner">
    {pricing.ctas.length ? (
      <div class="section-actions">
        {pricing.ctas.map((action) => (
          <a
            class="button button-primary"
            href={action.href}
            target={isExternal(action.href) ? "_blank" : undefined}
            rel={isExternal(action.href) ? "noreferrer" : undefined}
          >
            {action.label}
            <Icon name="ArrowRight" class="button-icon" size={16} />
          </a>
        ))}
      </div>
    ) : null}
  </div>
</section>
