---
import {
  ArrowRight,
  BadgeCheck,
  CalendarCheck,
  ChartNoAxesCombined,
  CircleCheck,
  TrendingUp,
  HeartPulse,
  Compass,
  Hospital,
  Eye,
  EyeOff,
  FileText,
  PillBottle,
  Handshake,
  HelpCircle,
  MessagesSquare,
  Network,
  PenLine,
  Route,
  ShieldCheck,
  Stethoscope,
  Target,
  UserCheck
} from "@lucide/astro";

interface Props {
  name: string;
  class?: string;
  size?: number;
  strokeWidth?: number;
}

const icons: Record<string, any> = {
  ArrowRight,
  BadgeCheck,
  CalendarCheck,
  ChartNoAxesCombined,
  HeartPulse,
  CircleCheck,
  Compass,
  TrendingUp,
  Hospital,
  Eye,
  EyeOff,
  FileText,
  Handshake,
  HelpCircle,
  MessagesSquare,
  Network,
  PenLine,
  Route,
  ShieldCheck,
  PillBottle,
  Stethoscope,
  Target,
  UserCheck
};

const {
  name,
  class: className = "icon",
  size = 20,
  strokeWidth = 1.8
} = Astro.props;

const Component = icons[name] ?? BadgeCheck;
---

<Component class={className} size={size} stroke-width={strokeWidth} aria-hidden="true" />
