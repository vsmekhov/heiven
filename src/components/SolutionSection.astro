---
import Icon from "./Icon.astro";
import { landing } from "../../content/landing";
import { emphasize } from "../utils/richText";

const { solution } = landing;

const actions = solution.ctas ?? [];
const isExternal = (href: string) => href.startsWith("http");

const solutionHighlights = [
  ["des dizaines de followers de Heiven me demandent où trouver un médecin ou un praticien en santé intégrative et fonctionnelle,"],
  ["ils vous trouveront directement dans le feed de Heiven."],
  ["La demande est là."],
  ["la référence francophone en santé fonctionnelle, médecine intégrative et longévité."],
  ["Plus de 680 000 personnes", "plus de 300 000 abonnés sur nos deux comptes Instagram"],
  ["nos contenus sont vus plusieurs millions de fois chaque mois."],
  ["des patients en errance médicale"],
  ["des professionnels comme vous, qui aiment transmettre leur savoir et savent les prendre en charge."],
  ["C'est exactement l'audience que vous cherchez à atteindre."]
];

const stepHighlights = [
  ["Étape 1 - Vous créez votre contenu."],
  ["Étape 2 - Publication"],
  ["Étape 3 - Découverte et engagement"]
];

const stepBodyHighlights = [
  [],
  ["Vous publiez depuis votre compte"],
  ["Vos futurs patients vous découvrent."]
];
---

<section class="section section-muted" id="solution" aria-labelledby="solution-title">
  <div class="section-inner editorial-layout">
    <div class="section-heading section-lede">
      {solution.eyebrow ? <p class="eyebrow">{solution.eyebrow}</p> : null}
      <h2 id="solution-title">{solution.title}</h2>
    </div>

    <article class="story-panel story-panel-primary">
      <div class="problem-copy-block">
        {solution.paragraphs.map((paragraph, index) => (
          <p
            class={index === 2 ? "section-intro lead-paragraph" : "section-intro"}
            set:html={emphasize(paragraph, solutionHighlights[index] ?? [])}
          ></p>
        ))}
      </div>
    </article>

    <div class="section-copy method-heading">
      <h3 class="chapter-title">{solution.methodTitle}</h3>
    </div>

    <div class="step-grid">
      {solution.steps.map((step, index) => (
        <article class="step-card">
          <div class="step-top">
            <Icon name="CircleCheck" class="step-icon" />
            <span>Étape {index + 1}</span>
          </div>
          <h3 set:html={emphasize(step.title, stepHighlights[index] ?? [])}></h3>
          {step.paragraphs.map((para) => (
            <p set:html={emphasize(para, stepBodyHighlights[index] ?? [])}></p>
          ))}
        </article>
      ))}
    </div>

    {actions.length ? (
      <div class="section-actions">
        {actions.map((action) => (
          <a
            class="button button-primary"
            href={action.href}
            target={isExternal(action.href) ? "_blank" : undefined}
            rel={isExternal(action.href) ? "noreferrer" : undefined}
          >
            {action.label}
            <Icon name="ArrowRight" class="button-icon" size={16} />
          </a>
        ))}
      </div>
    ) : null}
  </div>
</section>
