---
import Icon from "./Icon.astro";
import { landing } from "../../content/landing";
import { emphasize } from "../utils/richText";

const { experts } = landing;

const actions = experts.ctas ?? [];
const isExternal = (href: string) => href.startsWith("http");

// Initiales pour le placeholder quand aucun portrait n'est encore fourni.
const initials = (name: string) =>
  name
    .replace(/^(Professeur|Pr|Dr|Dre)\.?\s+/i, "")
    .split(/\s+/)
    .slice(0, 2)
    .map((part) => part.charAt(0).toUpperCase())
    .join("");

const associationHighlights = [
  ["Sur Heiven, vous ne publiez pas seul dans votre coin."],
  ["les références absolues de la santé fonctionnelle francophone."]
];

const testimonialHighlights = [
  ["gagner en visibilité, à remplir leur agenda, à faire connaître leur travail."]
];
---

<section class="section section-dark" id="association" aria-labelledby="experts-title">
  <div class="section-inner">
    <div class="section-heading experts-heading">
      <h2 id="experts-title">{experts.associationTitle}</h2>
      <div class="problem-copy-block">
        {experts.associationParagraphs.map((paragraph, index) => (
          <p class="section-intro" set:html={emphasize(paragraph, associationHighlights[index] ?? [])}></p>
        ))}
      </div>
    </div>

    <div class="people-wall reference-list">
      {experts.associationPeople.map((person) => (
        <figure class="person-tile">
          {person.image ? (
            <div class="person-photo">
              <img
                src={person.image}
                alt={person.alt}
                loading="lazy"
                decoding="async"
                style={[
                  person.objectPosition ? `object-position:${person.objectPosition}` : null,
                  person.scale ? `transform:scale(${person.scale})` : null,
                  person.scale && person.objectPosition ? `transform-origin:${person.objectPosition}` : null
                ].filter(Boolean).join(";") || undefined}
              />
            </div>
          ) : (
            <span class="person-placeholder" aria-hidden="true">{initials(person.name)}</span>
          )}
          <figcaption>{person.name}</figcaption>
        </figure>
      ))}
    </div>

    <p
      class="section-intro expert-note"
      set:html={emphasize(experts.associationImageNote, ["je peux faire confiance à ce praticien."])}
    ></p>

    <div class="section-copy testimonial-section">
      <h3 class="chapter-title">{experts.testimonialsTitle}</h3>
      <p class="section-intro" set:html={emphasize(experts.testimonialsLead, testimonialHighlights[0])}></p>
      <p class="section-intro">{experts.testimonialNote}</p>
      {experts.testimonials?.length ? (
        <div class="testimonials-gallery">
          {experts.testimonials.map((item) => (
            <figure class="testimonial-media-card">
              {item.type === "video" ? (
                <video src={item.src} controls preload="metadata" playsinline></video>
              ) : (
                <img src={item.src} alt={`Témoignage de ${item.name}`} loading="lazy" decoding="async" />
              )}
              <figcaption>
                <span class="tm-name">{item.name}</span>
              </figcaption>
            </figure>
          ))}
        </div>
      ) : null}
    </div>

    {actions.length ? (
      <div class="section-actions">
        {actions.map((action) => (
          <a
            class="button button-primary"
            href={action.href}
            target={isExternal(action.href) ? "_blank" : undefined}
            rel={isExternal(action.href) ? "noreferrer" : undefined}
          >
            {action.label}
            <Icon name="ArrowRight" class="button-icon" size={16} />
          </a>
        ))}
      </div>
    ) : null}
  </div>
</section>
