---
import Icon from "./Icon.astro";
import { landing } from "../../content/landing";
import { emphasize } from "../utils/richText";

const { faq } = landing;

const actions = faq.ctas ?? [];
const isExternal = (href: string) => href.startsWith("http");

const answerHighlights = [
  ["Edit d'Instagram, Captions ou CapCut, en moins de trente minutes."],
  ["Deux à trois heures une fois le rythme pris."],
  ["communauté de plus de 300 000 personnes qui ne vous connaissent pas encore"],
  ["Oui, dans votre légende et votre biographie."],
  ["« comment avez-vous entendu parler de moi ? »"],
  ["Le principe de déductibilité des charges professionnelles s'applique dans la plupart des pays"],
  ["50 praticiens"]
];
---

<section class="section section-light" id="faq" aria-labelledby="faq-title">
  <div class="section-inner faq-layout">
    <div class="section-copy">
      <h2 id="faq-title">{faq.title}</h2>
    </div>

    <div class="faq-list">
      {faq.items.map((item, index) => (
        <details>
        <summary>
          <Icon name="HelpCircle" class="summary-icon" size={18} />
          <span>{item.question}</span>
        </summary>
          <p set:html={emphasize(item.answer, answerHighlights[index] ?? [])}></p>
      </details>
    ))}
    </div>
  </div>

  {actions.length ? (
    <div class="section-inner section-actions">
      {actions.map((action) => (
        <a
          class="button button-primary"
          href={action.href}
          target={isExternal(action.href) ? "_blank" : undefined}
          rel={isExternal(action.href) ? "noreferrer" : undefined}
        >
          {action.label}
          <Icon name="ArrowRight" class="button-icon" size={17} />
        </a>
      ))}
    </div>
  ) : null}
</section>
